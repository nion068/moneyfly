{
  "name": "moneyfly",
  "version": "0.0.1",
  "description": "An open-source Expo client for self-hosted Firefly III personal finance servers.",
  "private": true,
  "license": "MIT",
  "author": "Nion",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nion068/moneyfly.git"
  },
  "bugs": {
    "url": "https://github.com/nion068/moneyfly/issues"
  },
  "homepage": "https://github.com/nion068/moneyfly#readme",
  "keywords": [
    "expo",
    "firefly-iii",
    "personal-finance",
    "react-native"
  ],
  "packageManager": "pnpm@11.5.0",
  "main": "index.tsx",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "APP_VARIANT=development expo prebuild --clean --platform android && APP_VARIANT=development expo run:android",
    "ios": "APP_VARIANT=development expo prebuild --clean --platform ios && APP_VARIANT=development expo run:ios",
    "web": "expo start --web",
    "bundle:web": "expo export --platform web",
    "serve:web": "npx serve dist",
    "generate:icons": "node scripts/generate-app-icons.mjs",
    "prebuild:clean": "expo prebuild --clean",
    "compile": "tsc --noEmit -p . --pretty",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "deps:check": "depcruise app --config .dependency-cruiser.js",
    "depcruise:graph": "depcruise app --include-only \"^app\" --config .dependency-cruiser.js --output-type dot > app-dependency-graph.dot && dot -T svg app-dependency-graph.dot -o app-dependency-graph.svg && dot -T png app-dependency-graph.dot -o app-dependency-graph.png && rm app-dependency-graph.dot",
    "align-deps": "expo install --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:maestro": "maestro test -e MAESTRO_APP_ID=${MAESTRO_APP_ID:-com.moneyfly.dev} .maestro/flows",
    "adb": "adb reverse tcp:9090 tcp:9090 && adb reverse tcp:3000 tcp:3000 && adb reverse tcp:9001 tcp:9001 && adb reverse tcp:8081 tcp:8081",
    "build:ios:sim": "eas build --profile development --platform ios --local",
    "build:ios:device": "eas build --profile development:device --platform ios --local",
    "build:ios:preview": "eas build --profile preview --platform ios --local",
    "build:ios:prod": "eas build --profile production --platform ios --local",
    "build:android:sim": "eas build --profile development --platform android --local",
    "build:android:device": "eas build --profile development:device --platform android --local",
    "build:android:preview": "eas build --profile preview --platform android --local",
    "build:android:prod": "eas build --profile production --platform android --local",
    "build:android:preview:cloud": "eas build --profile preview --platform android --non-interactive --no-wait",
    "build:android:prod:cloud": "eas build --profile production --platform android --non-interactive --no-wait"
  },
  "dependencies": {
    "@expo-google-fonts/space-grotesk": "^0.4.0",
    "@expo/metro-runtime": "~55.0.6",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/native": "^7.0.14",
    "@react-navigation/native-stack": "^7.2.0",
    "apisauce": "3.1.1",
    "date-fns": "^4.1.0",
    "expo": "~55.0.26",
    "expo-application": "~55.0.8",
    "expo-build-properties": "~55.0.9",
    "expo-dev-client": "~55.0.11",
    "expo-font": "~55.0.4",
    "expo-linking": "~55.0.7",
    "expo-local-authentication": "~55.0.14",
    "expo-localization": "~55.0.8",
    "expo-secure-store": "~55.0.14",
    "expo-splash-screen": "~55.0.10",
    "expo-system-ui": "~55.0.9",
    "i18next": "^23.14.0",
    "intl-pluralrules": "^2.0.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-i18next": "^15.0.1",
    "react-native": "0.83.6",
    "react-native-edge-to-edge": "~1.6.1",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-keyboard-controller": "1.20.7",
    "react-native-mmkv": "3.3.3",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.4",
    "setimmediate": "^1.0.5"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.20.0",
    "@babel/runtime": "^7.20.0",
    "@testing-library/react-native": "^13.2.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.10",
    "babel-jest": "^29.2.1",
    "babel-preset-expo": "~55.0.22",
    "dependency-cruiser": "^17.0.2",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~55.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react-native": "^4.1.0",
    "eslint-plugin-reactotron": "^0.1.2",
    "jest": "~29.7.0",
    "jest-expo": "~55.0.9",
    "prettier": "^3.3.3",
    "react-test-renderer": "19.2.0",
    "reactotron-core-client": "^2.9.4",
    "reactotron-react-js": "^3.3.11",
    "reactotron-react-native": "^5.0.5",
    "reactotron-react-native-mmkv": "^0.2.6",
    "sharp": "^0.35.1",
    "ts-jest": "^29.1.1",
    "tsx": "^4.20.3",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
